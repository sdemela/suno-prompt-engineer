{
  "version": 2,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/api/generate",   "destination": "/api/generate.js" },
    { "source": "/api/checkout",   "destination": "/api/checkout.js" },
    { "source": "/api/webhook",    "destination": "/api/webhook.js" },
    { "source": "/api/credits",    "destination": "/api/credits.js" },
    { "source": "/api/save-email", "destination": "/api/save-email.js" },
    { "source": "/en/tool",        "destination": "/en/tool.html" },
    { "source": "/it/tool",        "destination": "/it/tool.html" },
    { "source": "/en",             "destination": "/en/index.html" },
    { "source": "/it",             "destination": "/it/index.html" }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "trailingSlash": false
}
