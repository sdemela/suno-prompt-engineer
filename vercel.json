{
  "version": 2,
  "functions": {
    "api/generate.js":  { "memory": 512, "maxDuration": 30 },
    "api/checkout.js":  { "memory": 256, "maxDuration": 10 },
    "api/webhook.js":   { "memory": 256, "maxDuration": 10 },
    "api/credits.js":   { "memory": 256, "maxDuration": 10 },
    "api/save-email.js":{ "memory": 256, "maxDuration": 10 }
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "X-XSS-Protection",         "value": "1; mode=block" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type",   "value": "application/xml; charset=utf-8" },
        { "key": "Cache-Control",  "value": "public, max-age=86400" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/en/tool",          "destination": "/public/en/tool.html" },
    { "source": "/it/tool",          "destination": "/public/it/tool.html" },
    { "source": "/en",               "destination": "/public/en/index.html" },
    { "source": "/it",               "destination": "/public/it/index.html" },
    { "source": "/og-image.png",     "destination": "/public/og-image.png" },
    { "source": "/og-image.svg",     "destination": "/public/og-image.svg" },
    { "source": "/favicon.svg",      "destination": "/public/favicon.svg" },
    { "source": "/favicon.ico",      "destination": "/public/favicon.ico" },
    { "source": "/apple-touch-icon.png", "destination": "/public/apple-touch-icon.png" },
    { "source": "/logo.png",         "destination": "/public/logo.png" },
    { "source": "/sitemap.xml",      "destination": "/public/sitemap.xml" },
    { "source": "/robots.txt",       "destination": "/public/robots.txt" },
    { "source": "/ads.txt",          "destination": "/public/ads.txt" },
    { "source": "/google:path*",     "destination": "/public/google:path*" },
    { "source": "/",                 "destination": "/public/en/index.html" }
  ],
  "redirects": [
    { "source": "/en/", "destination": "/en", "permanent": false },
    { "source": "/it/", "destination": "/it", "permanent": false }
  ],
  "trailingSlash": false
}
