{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.js" },
    { "src": "/api/checkout", "dest": "/api/checkout.js" },
    { "src": "/api/webhook", "dest": "/api/webhook.js" },
    { "src": "/api/credits", "dest": "/api/credits.js" },
    { "src": "/en", "dest": "/public/en/index.html" },
    { "src": "/en/", "dest": "/public/en/index.html" },
    { "src": "/it", "dest": "/public/it/index.html" },
    { "src": "/it/", "dest": "/public/it/index.html" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
